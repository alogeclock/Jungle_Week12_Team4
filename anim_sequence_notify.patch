+void UAnimSequenceBase::ClearNotifies()
+{
+	Notifies.clear();
+}
+
+bool UAnimSequenceBase::RemoveNotifyAt(int32 NotifyIndex)
+{
+	if (NotifyIndex < 0 || NotifyIndex >= static_cast<int32>(Notifies.size()))
+	{
+		return false;
+	}
+
+	Notifies.erase(Notifies.begin() + NotifyIndex);
+	return true;
+}
