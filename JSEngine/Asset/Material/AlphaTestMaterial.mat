        { "Name": "DiffuseColor", "Type": "Vector3", "Value": [1.0, 0.25, 0.05] },
        { "Name": "SpecularColor", "Type": "Vector3", "Value": [0.2, 0.2, 0.2] },
        { "Name": "EmissiveColor", "Type": "Vector3", "Value": [1.0, 0.2, 0.0] },
        { "Name": "Shininess", "Type": "Float", "Value": 8.0 },
        { "Name": "Opacity", "Type": "Float", "Value": 0.75 },
        { "Name": "bHasDiffuseMap", "Type": "Bool", "Value": true },
        { "Name": "bHasSpecularMap", "Type": "Bool", "Value": false },
        { "Name": "bHasAmbientMap", "Type": "Bool", "Value": false },
        { "Name": "bHasEmissiveMap", "Type": "Bool", "Value": false },
        { "Name": "bHasBumpMap", "Type": "Bool", "Value": false },
